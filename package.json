  "scripts": {
    "version:set": "bash scripts/bump-version.sh",
    "build:prod-zip": "bash scripts/build-prod-zip.sh",
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "NODE_OPTIONS=--max-old-space-size=1536 vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist --alias:@diploy/core=./packages/diploy-core/index.ts",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:precheck": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f scripts/prod-v37-precheck-and-cleanup.sql",
    "db:upgrade": "npm run db:precheck && drizzle-kit push --force",
    "db:update": "drizzle-kit generate && drizzle-kit push",
    "seed": "tsx server/seed.ts",
    "studio": "prisma studio --port 4444",
    "db:studio": "drizzle-kit studio",
    "update:code": "git pull && npm run build && npm run db:push -- --force && pm2 restart all && pm2 logs",
    "db:seed": "tsx server/seed-all.ts",
    "test": "vitest run"
  },
