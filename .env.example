# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/database_name

# Session Configuration
SESSION_SECRET=xxxxxxxxxxxxx

# WhatsApp Business API Configuration
WHATSAPP_API_VERSION=v24.0
WHATSAPP_BUSINESS_ACCOUNT_ID=x
WHATSAPP_ACCESS_TOKEN=xxx
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
# Required for carousel templates and embedded signup
FACEBOOK_APP_ID=your_meta_app_id

# MM Lite API Configuration 
# Note: MM Lite uses the same WhatsApp Cloud API but with /marketing_messages endpoint
# No separate API key needed - uses same access token as WhatsApp Business API
# Marketing messages automatically use /marketing_messages endpoint for higher throughput


# Application Configuration
APP_URL=https://yourdomain.example
PORT=5000
NODE_ENV=production
FORCE_HTTPS=false

# Optional: Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Optional: Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379

# Optional: Sentry Configuration (for error tracking)
SENTRY_DSN=your_sentry_dsn

# Debug Mode (set to true for verbose logging)
DEBUG=false
LOG_LEVEL=info

# Optional: Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: Campaign Message Queue Tuning
# MESSAGE_QUEUE_CONCURRENCY — parallel API calls per channel (auto-detected from tier if unset)
# MESSAGE_QUEUE_BATCH_SIZE  — messages fetched per polling cycle (default: 200)
# MESSAGE_SEND_DELAY_MS     — extra delay in ms between sends, 0 = no delay (default: 0)
# WHATSAPP_MESSAGING_TIER   — fallback tier if not detected from channel health (default: TIER_10K)
#   Tiers: TIER_250 (1/sec), TIER_1K (4/sec), TIER_10K (80/sec), TIER_100K (500/sec), UNLIMITED (1000/sec)
# MESSAGE_QUEUE_CONCURRENCY=20
# MESSAGE_QUEUE_BATCH_SIZE=200
# MESSAGE_SEND_DELAY_MS=0
# WHATSAPP_MESSAGING_TIER=TIER_10K

OPENAI_API_KEY=xx
RAZORPAY_KEY_ID=xxx
RAZORPAY_KEY_SECRET=xx


STRIPE_SECRET_KEY=xxx
STRIPE_PUBLISHABLE_KEY=xx